{
    "family": "hello-sre-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "hello-container",
            "image": "545009864726.dkr.ecr.us-east-1.amazonaws.com/hello-sre-repo:latest",
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "essential": true
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::545009864726:role/ecsTaskExecutionRole"
}
